# ═══════════════════════════════════════════════════════════════
# FILE: .env.example (Laravel backend)
# ═══════════════════════════════════════════════════════════════
APP_NAME="BLOOSAT BSS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bloosat_bss
DB_USERNAME=root
DB_PASSWORD=

QUEUE_CONNECTION=database

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="bss@bloosat.com"
MAIL_FROM_NAME="BLOOSAT BSS"

# Email destinataires système
ACCOUNTING_EMAIL=comptabilite@bloosat.com

# External APIs
SUSPENSION_API_URL=https://your-suspension-api.com/api
SUSPENSION_API_KEY=your_suspension_api_key

KAF_URL=https://api.kaf.example.com
KAF_KEY=your_kaf_api_key

IWAY_URL=https://api.iway.example.com
IWAY_KEY=your_iway_api_key

SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000

FILESYSTEM_DISK=local
